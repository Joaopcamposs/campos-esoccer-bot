TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
TELEGRAM_CHANNEL_ID=-1001234567890
DATABASE_URL=postgresql+asyncpg://app:app@localhost:54311/app
TELEGRAM_POLLING=true
LOG_LEVEL=INFO

# Timezones dos sites de scraping
# Aceodds: retorna horários na timezone do IP que acessa
#   Brasil: America/Sao_Paulo | EUA: verificar via /api/debug/aceodds-raw
# Totalcorner: retorna horários em Europe/London (BST no verão, GMT no inverno)
#   Verificar via /api/debug/totalcorner-raw se mudar de servidor
ACEODDS_TIMEZONE=America/Sao_Paulo
TOTALCORNER_TIMEZONE=Europe/London

# Schema PostgreSQL para isolamento multi-tenant (vazio = public)
DB_SCHEMA=esoccer_bot
